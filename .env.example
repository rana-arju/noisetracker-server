# Server Configuration
NODE_ENV=production
PORT=5000
API_BASE_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/emailsystem

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets
JWT_ACCESS_SECRET=your-access-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_RESET_PASS_SECRET=your-reset-password-secret-key-here

# JWT Expiration Times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_PASS_EXPIRES_IN=10m
JWT_STORE_ADDRESS_EXPIRES_IN=1h
OTP_ACCESS_EXPIRES_IN=5m

# Admin Configuration
SUPER_ADMIN_PASSWORD=your-super-admin-password
BCRYPT_SALT_ROUNDS=10

# Email Configuration
EMAIL=your-email@example.com
EMAIL_PASSWORD=your-email-password
CONTACT_MAIL_ADDRESS=contact@example.com

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket-name
SES_CONFIGURATION_SET=your-ses-configuration-set

# Steadfast Courier Configuration
STEADFAST_API_KEY=your-steadfast-api-key
STEADFAST_SECRET_KEY=your-steadfast-secret-key
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_WEBHOOK_SECRET=your-webhook-secret-token
